{
	"name": "grabit-engine",
	"version": "1.2.0-alpha.0",
	"type": "module",
	"description": "A plugin-based engine for scraping media streams and subtitles. Works in Node.js, browsers, React and React Native. Load plugins from GitHub, local files, or code — with caching, health tracking, and auto-updates built in.",
	"author": "imroodydev",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ImRoodyDev/grabit-engine.git"
	},
	"homepage": "https://github.com/ImRoodyDev/grabit-engine#readme",
	"bugs": {
		"url": "https://github.com/ImRoodyDev/grabit-engine/issues"
	},
	"license": "ISC",
	"keywords": [
		"scraper",
		"stream",
		"media",
		"plugin",
		"provider",
		"engine",
		"subtitles",
		"streaming",
		"react-native",
		"tmdb",
		"cheerio",
		"puppeteer",
		"proxy",
		"cloudflare-bypass",
		"impit"
	],
	"source": "./src/index.ts",
	"main": "./dist/cjs/src/index.js",
	"module": "./dist/esm/src/index.js",
	"types": "./dist/esm/src/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/esm/src/index.d.ts",
			"react-native": "./src/index.ts",
			"node": {
				"types": "./dist/esm/src/index.node.d.ts",
				"import": "./dist/esm/src/index.node.js",
				"require": "./dist/cjs/src/index.js"
			},
			"import": "./dist/esm/src/index.js",
			"require": "./dist/cjs/src/index.js",
			"default": "./dist/cjs/src/index.js"
		},
		"./react": {
			"types": "./dist/esm/src/hooks/useSources.d.ts",
			"react-native": "./src/hooks/useSources.ts",
			"import": "./dist/esm/src/hooks/useSources.js",
			"require": "./dist/esm/src/hooks/useSources.js",
			"default": "./dist/esm/src/hooks/useSources.js"
		}
	},
	"files": [
		"dist/esm",
		"dist/cjs",
		"src",
		"scripts",
		"CHANGELOG.md",
		"README.md",
		"BUNDLING.md",
		"API_REFERENCE.md",
		"LICENSE"
	],
	"bin": {
		"create-provider": "./scripts/create-provider.js",
		"bundle-provider": "./scripts/bundle-provider.js",
		"test-provider": "./scripts/test-provider.js"
	},
	"scripts": {
		"watch": "tsc -w",
		"test": "jest",
		"build": "tsc -p tsconfig.json && node scripts/build-cjs.js && node scripts/postbuild.js",
		"build:local": "npm run build && npm pack",
		"prepublishOnly": "npm run build",
		"create-provider": "node scripts/create-provider.js",
		"bundle": "node scripts/bundle-provider.js",
		"bundle:clean": "node scripts/bundle-provider.js --clean",
		"test-provider": "node scripts/test-provider.js",
		"publish:npm": "npx -p dotenv-cli dotenv -e .env -- npm publish",
		"publish:alpha:npm": "npx -p dotenv-cli dotenv -e .env -- npm publish --tag alpha"
	},
	"devDependencies": {
		"@babel/preset-env": "^7.29.0",
		"@babel/preset-typescript": "^7.28.5",
		"@types/base-64": "^1.0.2",
		"@types/jest": "^30.0.0",
		"@types/node": "^25.2.2",
		"@types/react": "^19.2.14",
		"@types/validator": "^13.15.10",
		"base-64": "^1.0.0",
		"esbuild": "^0.27.3",
		"jest": "^30.2.0",
		"typescript": "5.8.3"
	},
	"dependencies": {
		"base-64": "^1.0.0",
		"cheerio": "^1.2.0",
		"http-proxy-agent": "^7.0.2",
		"https-proxy-agent": "^7.0.6",
		"impit": "^0.10.1",
		"iso-639-1": "^3.1.5",
		"node-fetch": "^3.3.2",
		"p-limit": "^7.3.0",
		"parse-duration": "^2.1.5",
		"socks-proxy-agent": "^8.0.5",
		"tldts": "^7.0.24",
		"validator": "^13.15.26"
	},
	"optionalDependencies": {
		"puppeteer-real-browser": "^1.4.4"
	},
	"peerDependencies": {
		"puppeteer-real-browser": "^1.4.4",
		"react-native-quick-crypto": "^0.7.17",
		"react": ">=17.0.0"
	},
	"peerDependenciesMeta": {
		"puppeteer-real-browser": {
			"optional": true
		},
		"react-native-quick-crypto": {
			"optional": true
		},
		"react": {
			"optional": true
		}
	}
}
