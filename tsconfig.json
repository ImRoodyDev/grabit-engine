{
	// Visit https://aka.ms/tsconfig to read more about this file
	"compilerOptions": {
		// File Layout
		"rootDir": ".",
		"outDir": "./dist",

		// Environment Settings
		// See also https://aka.ms/tsconfig/module
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"target": "esnext",
		"lib": ["esnext", "dom"],
		"types": ["node"],
		// For nodejs:
		// "lib": ["esnext"],
		// "types": ["node"],
		// and npm install -D @types/node

		// Other Outputs
		"sourceMap": false,
		"declaration": true,
		"declarationMap": false,

		// Stricter Typechecking Options
		// "noUncheckedIndexedAccess": true,
		"resolveJsonModule": true,
		// "exactOptionalPropertyTypes": true,

		// Style Options
		"allowUnreachableCode": false,
		"allowUnusedLabels": false,
		"forceConsistentCasingInFileNames": true,
		"noFallthroughCasesInSwitch": true,
		"noImplicitReturns": true,
		"noImplicitUseStrict": false,
		"noStrictGenericChecks": false,
		// "noImplicitOverride": true,
		// "noUnusedLocals": true,
		// "noUnusedParameters": true,
		// "noPropertyAccessFromIndexSignature": true,

		// Recommended Options
		"strict": true,
		"jsx": "react-jsx",
		// "verbatimModuleSynatx": true,
		// "isolatedModules": true,
		"noUncheckedSideEffectImports": true,
		// "moduleDetection": "force",
		"skipLibCheck": true,
		// Rewrite extensionless relative imports to .js in the output so dist files
		// can be loaded directly by Node.js ESM without a bundler (e.g. test-provider CLI).
		"rewriteRelativeImportExtensions": true
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist", "tests", "**/*.test.*", "**/*.config.js"]
}
